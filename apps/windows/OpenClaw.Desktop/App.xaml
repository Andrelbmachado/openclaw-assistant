<Application x:Class="OpenClaw.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0B0E14" />
    <SolidColorBrush x:Key="PanelBrush" Color="#121720" />
    <SolidColorBrush x:Key="TextBrush" Color="#F4F6F8" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#98A3B3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF5C5C" />
  </Application.Resources>
</Application>
