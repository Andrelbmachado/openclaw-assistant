<Window x:Class="OpenClaw.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="OpenClaw"
        Width="1360"
        Height="860"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="44" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#10141C" BorderBrush="#222936" BorderThickness="0,0,0,1">
      <Grid Margin="14,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#F59E0B" Margin="0,0,9,0" />
          <TextBlock x:Name="StatusText" Text="Starting Gateway" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" FontSize="12" />
        </StackPanel>

        <TextBlock Grid.Column="1" Text="OpenClaw" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="ReloadButton" Content="Reload" Click="ReloadButton_Click" Margin="0,0,8,0" Padding="12,5" />
          <Button x:Name="BrowserButton" Content="Open in browser" Click="BrowserButton_Click" Padding="12,5" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <wv2:WebView2 x:Name="Browser" Visibility="Collapsed" />

      <Grid x:Name="UnavailablePanel" Background="{StaticResource WindowBackgroundBrush}">
        <Border Width="560" Padding="36" Background="{StaticResource PanelBrush}" CornerRadius="20" HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel>
            <TextBlock Text="OpenClaw Gateway is not available" Foreground="{StaticResource TextBrush}" FontSize="25" FontWeight="SemiBold" TextWrapping="Wrap" />
            <TextBlock x:Name="UnavailableDetail" Margin="0,14,0,24" Foreground="{StaticResource MutedTextBrush}" FontSize="14" LineHeight="22" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal">
              <Button Content="Try again" Click="TryAgainButton_Click" Padding="18,9" Margin="0,0,10,0" />
              <Button Content="Open web address" Click="BrowserButton_Click" Padding="18,9" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
